{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cursor-llm-council/config.schema.json",
  "title": "LLM Council Config",
  "description": "Configuration schema for cursor-llm-council",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1],
      "description": "Config schema version"
    },
    "default_tier": {
      "type": "string",
      "enum": ["budget", "standard", "premium"],
      "default": "standard"
    },
    "default_mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep"],
      "default": "standard"
    },
    "supervisor_enabled": {
      "type": "boolean",
      "default": true
    },
    "transcript_dir": {
      "type": "string",
      "default": ".cursor/council-sessions"
    },
    "members": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["model"],
        "properties": {
          "model": { "type": "string" },
          "fallback": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "supervisor": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "fallback": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "red_team": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "fallback": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tiers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "scoring_weights": {
      "type": "object",
      "properties": {
        "feasibility": { "type": "number", "minimum": 0, "maximum": 1 },
        "security": { "type": "number", "minimum": 0, "maximum": 1 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 1 },
        "cost": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "sensitive_file_blocklist": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
